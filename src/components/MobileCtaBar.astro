---
import { INSTAGRAM_URL } from '../config';
---

<a
  id="mobile-cta-bar"
  href={INSTAGRAM_URL}
  target="_blank"
  rel="noopener noreferrer"
  class="fixed inset-x-3 bottom-3 z-30 flex translate-y-[120%] items-center justify-center gap-2 rounded-full bg-[var(--color-accent)] px-6 py-4 text-sm font-medium uppercase tracking-wider text-[var(--color-cream)] shadow-[0_18px_30px_-12px_rgba(160,40,40,0.5)] transition-transform duration-500 md:hidden"
  aria-label="Записатися на 3 потік через Instagram"
>
  Записатися на 3 потік
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <line x1="5" y1="12" x2="19" y2="12" />
    <polyline points="12 5 19 12 12 19" />
  </svg>
</a>

<script is:inline>
  (function () {
    const bar = document.getElementById('mobile-cta-bar');
    if (!bar) return;
    let visible = false;
    const update = () => {
      const shouldShow = window.scrollY > window.innerHeight * 0.6;
      if (shouldShow === visible) return;
      visible = shouldShow;
      bar.style.transform = shouldShow ? 'translateY(0)' : 'translateY(120%)';
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
  })();
</script>
