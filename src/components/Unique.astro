---
import { Image } from 'astro:assets';
import { unique } from '../data/content';
import { AUTHOR } from '../config';
import uniqueImg from '../assets/img/unique-portrait.jpg';
---

<section id="unique" class="py-24 md:py-32">
  <div class="mx-auto grid max-w-7xl items-start gap-14 px-5 md:px-8 lg:grid-cols-[1.1fr_1fr]">
    <div class="reveal">
      <p class="text-xs uppercase tracking-[0.28em] text-[var(--color-ink-soft)]">Авторка програми</p>
      <h2 class="mt-3 font-display text-5xl text-[var(--color-ink)] md:text-6xl">
        {AUTHOR.fullName}
      </h2>
      <p class="mt-4 text-base leading-relaxed text-[var(--color-ink-soft)]">
        {AUTHOR.roles.join(' · ')}
      </p>
      <p class="mt-2 text-base italic text-[var(--color-accent)]">{AUTHOR.description}</p>

      <dl class="mt-8 grid grid-cols-3 gap-4 border-y border-[var(--color-gold)]/30 py-6">
        {
          AUTHOR.stats.map((s) => (
            <div>
              <dt class="text-[10px] uppercase tracking-[0.18em] text-[var(--color-ink-soft)] md:text-xs">
                {s.label}
              </dt>
              <dd class="mt-1 font-display text-3xl text-[var(--color-accent)] md:text-4xl">
                {s.value}
              </dd>
            </div>
          ))
        }
      </dl>

      <p class="section-title mt-12 text-4xl md:text-5xl">{unique.title}</p>
      <div class="mt-6 h-px w-20 bg-[var(--color-gold)]"></div>

      <div class="mt-8 space-y-5 text-lg leading-relaxed text-[var(--color-ink-soft)]">
        {unique.paragraphs.map((p) => <p>{p}</p>)}
      </div>

      <div class="mt-10 rounded-3xl bg-[var(--color-card)] p-7 shadow-[var(--shadow-card)] ring-1 ring-[var(--color-gold)]/15">
        <p class="font-display text-2xl text-[var(--color-accent)]">Ви навчитеся бачити:</p>
        <ul class="mt-5 grid gap-3 text-base text-[var(--color-ink-soft)] md:grid-cols-2">
          {
            unique.willSee.map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-2 block h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-accent)]" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="reveal sticky top-28 self-start">
      <Image
        src={uniqueImg}
        alt={`${AUTHOR.fullName} — авторка курсу`}
        widths={[400, 600, 800]}
        sizes="(max-width: 1024px) 92vw, 480px"
        format="webp"
        quality={82}
        class="aspect-[9/14] w-full max-w-md rounded-[2rem] object-cover shadow-[var(--shadow-soft)]"
      />
    </div>
  </div>
</section>
