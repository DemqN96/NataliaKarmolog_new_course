---
import { program } from '../data/content';
---

<section id="program" class="bg-[var(--color-cream-soft)] py-24 md:py-32">
  <div class="mx-auto max-w-5xl px-5 md:px-8">
    <div class="reveal max-w-3xl">
      <p class="section-title text-4xl md:text-5xl">Структура курсу</p>
      <div class="mt-6 h-px w-20 bg-[var(--color-gold)]"></div>
    </div>

    <div class="mt-12 space-y-4">
      {
        program.map((block, idx) => (
          <details
            class="reveal group rounded-3xl bg-[var(--color-card)] shadow-[var(--shadow-card)] ring-1 ring-[var(--color-gold)]/15 transition-all open:ring-[var(--color-accent)]/30"
            open={idx === 0}
          >
            <summary class="flex cursor-pointer items-start gap-5 px-6 py-6 md:px-8 md:py-7 [&::-webkit-details-marker]:hidden">
              <span class="font-display text-4xl text-[var(--color-accent)] md:text-5xl shrink-0 leading-none">
                {String(block.block).padStart(2, '0')}
              </span>
              <div class="flex-1">
                <p class="text-xs uppercase tracking-[0.25em] text-[var(--color-ink-soft)]">Блок {block.block}</p>
                <h3 class="mt-1 font-display text-2xl text-[var(--color-ink)] md:text-3xl">
                  {block.title}
                </h3>
              </div>
              <svg
                class="chev mt-1 h-6 w-6 shrink-0 text-[var(--color-accent)]"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <polyline points="6 9 12 15 18 9" />
              </svg>
            </summary>

            <div class="border-t border-[var(--color-gold)]/30 px-6 py-6 md:px-8 md:py-7">
              <ul class="grid gap-3 text-[var(--color-ink-soft)] md:grid-cols-2">
                {block.items.map((item) => (
                  <li class="flex items-start gap-3 text-base leading-relaxed">
                    <span class="mt-2 block h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-accent)]" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
