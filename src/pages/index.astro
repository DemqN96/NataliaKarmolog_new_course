---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Benefits from '../components/Benefits.astro';
import CourseStructure from '../components/CourseStructure.astro';
import Format from '../components/Format.astro';
import Audience from '../components/Audience.astro';
import Unique from '../components/Unique.astro';
import Pricing from '../components/Pricing.astro';
import Testimonials from '../components/Testimonials.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
import MobileCtaBar from '../components/MobileCtaBar.astro';
---

<Base>
