---
import Base from '../layouts/Base.astro';
import { BANK_DETAILS, INSTAGRAM_URL, INSTAGRAM_HANDLE, COURSE } from '../config';

const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '/';
---

<Base
  title="Реквізити для оплати — Школа духовного розвитку"
  description="Банківські реквізити для оплати навчання в Школі духовного розвитку Наталії Кармолог."
>
  <div class="min-h-screen bg-[var(--color-cream)] px-5 py-12 md:px-8">

    <!-- Back link -->
    <div class="mx-auto max-w-2xl">
      <a
        href={base}
        class="inline-flex items-center gap-2 text-sm text-[var(--color-ink-soft)] hover:text-[var(--color-accent)] transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="19" y1="12" x2="5" y2="12" />
          <polyline points="12 19 5 12 12 5" />
        </svg>
        Повернутися на головну
      </a>
    </div>

    <!-- Card -->
    <main class="mx-auto mt-8 max-w-2xl">
      <div class="rounded-[2rem] bg-[var(--color-card)] p-8 shadow-[var(--shadow-card)] ring-1 ring-[var(--color-gold)]/20 md:p-10">

        <!-- Header -->
        <p class="text-xs uppercase tracking-[0.28em] text-[var(--color-ink-soft)]">3 потік · Старт {COURSE.startDateLabel}</p>
        <h1 class="mt-3 font-display text-4xl italic text-[var(--color-accent)] md:text-5xl">
          Реквізити для оплати
        </h1>
        <div class="mt-4 h-px w-16 bg-[var(--color-gold)]"></div>

        <!-- Details table -->
        <dl class="mt-8 space-y-4">
          <div class="rounded-2xl bg-[var(--color-cream-soft)] px-6 py-4">
            <dt class="text-xs uppercase tracking-wider text-[var(--color-ink-soft)]">Отримувач</dt>
            <dd class="mt-1 text-lg font-semibold text-[var(--color-ink)]">{BANK_DETAILS.recipient}</dd>
          </div>

          <div class="rounded-2xl bg-[var(--color-cream-soft)] px-6 py-4">
            <dt class="text-xs uppercase tracking-wider text-[var(--color-ink-soft)]">ІПН (ЄДРПОУ)</dt>
            <dd class="mt-1 flex items-center justify-between gap-3">
              <span class="font-mono text-lg font-semibold text-[var(--color-ink)]" id="ipn-val">{BANK_DETAILS.ipn}</span>
              <button
                class="copy-btn shrink-0 rounded-lg border border-[var(--color-gold)]/40 px-3 py-1.5 text-xs text-[var(--color-ink-soft)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
                data-copy={BANK_DETAILS.ipn}
                aria-label="Скопіювати ІПН"
              >Копіювати</button>
            </dd>
          </div>

          <div class="rounded-2xl bg-[var(--color-cream-soft)] px-6 py-4">
            <dt class="text-xs uppercase tracking-wider text-[var(--color-ink-soft)]">Банк</dt>
            <dd class="mt-1 text-lg font-semibold text-[var(--color-ink)]">{BANK_DETAILS.bank}</dd>
          </div>

          <div class="rounded-2xl bg-[var(--color-cream-soft)] px-6 py-4">
            <dt class="text-xs uppercase tracking-wider text-[var(--color-ink-soft)]">IBAN</dt>
            <dd class="mt-1 flex flex-wrap items-center justify-between gap-3">
              <span class="font-mono text-base font-semibold tracking-wide text-[var(--color-ink)] break-all" id="iban-val">{BANK_DETAILS.iban}</span>
              <button
                class="copy-btn shrink-0 rounded-lg border border-[var(--color-gold)]/40 px-3 py-1.5 text-xs text-[var(--color-ink-soft)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors"
                data-copy={BANK_DETAILS.iban}
                aria-label="Скопіювати IBAN"
              >Копіювати</button>
            </dd>
          </div>

          <div class="rounded-2xl border border-[var(--color-accent)]/25 bg-[var(--color-accent)]/5 px-6 py-4">
            <dt class="text-xs uppercase tracking-wider text-[var(--color-ink-soft)]">Призначення платежу</dt>
            <dd class="mt-1 flex flex-wrap items-center justify-between gap-3">
              <span class="text-base font-semibold text-[var(--color-accent)]" id="purpose-val">{BANK_DETAILS.purpose}</span>
              <button
                class="copy-btn shrink-0 rounded-lg border border-[var(--color-accent)]/40 px-3 py-1.5 text-xs text-[var(--color-accent)] hover:bg-[var(--color-accent)] hover:text-[var(--color-cream)] transition-colors"
                data-copy={BANK_DETAILS.purpose}
                aria-label="Скопіювати призначення"
              >Копіювати</button>
            </dd>
          </div>
        </dl>

        <!-- Instructions -->
        <div class="mt-8 rounded-2xl bg-[var(--color-ink)] px-6 py-5 text-[var(--color-cream)]">
          <p class="font-display text-lg italic text-[var(--color-gold)]">Як оплатити:</p>
          <ol class="mt-3 space-y-2 text-sm leading-relaxed text-[var(--color-cream)]/85">
            <li class="flex gap-2.5"><span class="font-semibold text-[var(--color-gold)]">1.</span> Відкрий свій банківський додаток (Monobank, Privat24, тощо).</li>
            <li class="flex gap-2.5"><span class="font-semibold text-[var(--color-gold)]">2.</span> Обери розділ <strong>"Інші платежі"</strong> або переказ за IBAN.</li>
            <li class="flex gap-2.5"><span class="font-semibold text-[var(--color-gold)]">3.</span> Вкажи IBAN вище та отримувача <strong>Войтович Наталія Вікторівна</strong>.</li>
            <li class="flex gap-2.5"><span class="font-semibold text-[var(--color-gold)]">4.</span> У полі <strong>"Призначення платежу"</strong> обов'язково вкажи: <em>"Оплата за онлайн-курс"</em>.</li>
            <li class="flex gap-2.5"><span class="font-semibold text-[var(--color-gold)]">5.</span> Після оплати — надішли скріншот чека в Direct Instagram.</li>
          </ol>
        </div>

        <!-- Note on installments -->
        <p class="mt-6 text-sm italic text-[var(--color-ink-soft)]">
          Оплата частинами або переказ з-за кордону — уточнюй деталі в Direct.
        </p>

        <!-- CTA back to Instagram -->
        <a
          href={INSTAGRAM_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 flex w-full items-center justify-center gap-3 rounded-2xl bg-gradient-to-r from-[#833ab4] via-[#fd1d1d] to-[#f77737] px-6 py-4 text-sm font-semibold uppercase tracking-widest text-white shadow-lg transition-opacity hover:opacity-90"
          aria-label="Написати в Instagram після оплати"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
          </svg>
          Написати після оплати — {INSTAGRAM_HANDLE}
        </a>

      </div>
    </main>

  </div>

  <script is:inline>
    document.querySelectorAll('.copy-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var text = btn.getAttribute('data-copy');
        if (!text) return;
        navigator.clipboard.writeText(text).then(function() {
          var original = btn.textContent;
          btn.textContent = 'Скопійовано ✓';
          setTimeout(function() { btn.textContent = original; }, 1800);
        }).catch(function() {
          // fallback: select text manually
          var el = document.createElement('textarea');
          el.value = text;
          document.body.appendChild(el);
          el.select();
          document.execCommand('copy');
          document.body.removeChild(el);
          var original = btn.textContent;
          btn.textContent = 'Скопійовано ✓';
          setTimeout(function() { btn.textContent = original; }, 1800);
        });
      });
    });
  </script>
</Base>
